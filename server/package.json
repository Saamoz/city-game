{
  "name": "@city-game/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:test:create": "node --import tsx src/db/scripts/create-test-db.ts",
    "db:test:drop": "node --import tsx src/db/scripts/drop-test-db.ts",
    "db:seed:dev": "node --import tsx src/db/scripts/seed-dev.ts",
    "db:seed:toronto": "node --import tsx src/db/scripts/seed-toronto.ts",
    "db:seed:chicago": "node --import tsx src/db/scripts/seed-chicago.ts"
  },
  "dependencies": {
    "@city-game/shared": "workspace:*",
    "@fastify/cookie": "11.0.2",
    "cookie": "^1.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "osmtogeojson": "3.0.0-beta.5",
    "pg": "^8.20.0",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}

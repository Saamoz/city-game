{
  "name": "@city-game/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "db:test:create": "tsx src/db/scripts/create-test-db.ts",
    "db:test:drop": "tsx src/db/scripts/drop-test-db.ts"
  },
  "dependencies": {
    "@city-game/shared": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}

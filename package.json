{
  "name": "city-game",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"pnpm dev:client\" \"pnpm dev:server\"",
    "build": "pnpm -r build",
    "start": "node server/dist/index.js",
    "prod:build": "pnpm build && pnpm db:migrate",
    "typecheck": "pnpm -r typecheck",
    "dev:client": "pnpm --filter @city-game/client dev",
    "dev:server": "pnpm --filter @city-game/server dev",
    "test": "pnpm --filter @city-game/server test",
    "db:up": "bash ./scripts/docker-compose.sh -f compose.yml up -d db",
    "db:down": "bash ./scripts/docker-compose.sh -f compose.yml down",
    "db:logs": "bash ./scripts/docker-compose.sh -f compose.yml logs -f db",
    "db:generate": "pnpm --filter @city-game/server db:generate",
    "db:migrate": "pnpm --filter @city-game/server db:migrate",
    "db:studio": "pnpm --filter @city-game/server db:studio",
    "db:test:create": "pnpm --filter @city-game/server db:test:create",
    "db:test:drop": "pnpm --filter @city-game/server db:test:drop",
    "db:seed:dev": "pnpm --filter @city-game/server db:seed:dev",
    "validate": "pnpm typecheck && pnpm test && pnpm build",
    "db:seed:toronto": "pnpm --filter @city-game/server db:seed:toronto",
    "db:seed:chicago": "pnpm --filter @city-game/server db:seed:chicago"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
